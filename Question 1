#include<iostream>
using namespace std;

bool power(int n){
    if(n<=0){
        return false;
    }
    while(n%2==0){

         n=n/2;
    }

   if(n==1){
    return true;
   }
   else{
    return false;
   }

}

int main(){
   
    int n;
    cout<<"Enter number: ";
    cin>>n;

    if(power(n))
        cout<<"Power of Two";
    else
        cout<<"Not Power of Two";

    return 0;
}
