#include<iostream>
using namespace std;
int countFactor(int n){
    int count=0;
    for(int i=1; i*i<=n;++i){
        if(n%i==0){
            if(i==n/i){
                count=count+1;
            }
            else{
                count=count+2;
            }
        }
        
    }
    return count;
}

int main(){
    int n;
    cin>>n;
    cout<<countFactor(n);
}
