#include <iostream>
#include <vector>
using namespace std;

int gcd(int a, int b){
    
    while(b != 0){
        int r = a % b;
        a = b;
        b = r;
    }
    
    return a;
}

int findGCD(vector<int>& nums) {

    int mn = nums[0];
    int mx = nums[0];

    for(int i = 0; i < nums.size(); i++){
        if(nums[i] < mn)
            mn = nums[i];

        if(nums[i] > mx)
            mx = nums[i];
    }

    return gcd(mn, mx);
}

int main(){

    vector<int> nums = {2,5,6,9,10};

    cout << findGCD(nums);

}
